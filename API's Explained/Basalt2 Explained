## Examples

### Creating a Simple UI

```lua
local basalt = require("main.lua")
local mainFrame = basalt.createFrame()

-- Create a container to hold elements
local container = basalt.create("Container", { x = 2, y = 2, width = 50, height = 20 })
mainFrame:addChild(container)

-- Add a label
local label = basalt.create("Label", { text = "Hello, Basalt!" })
container:addChild(label)

-- Add a button with a click callback
local button = basalt.create("Button", { text = "Press Me" })
button:registerCallback("mouse_click", function(self, button, x, y)
    print("Button was pressed!")
end)
container:addChild(button)

basalt.run()
```

### Using an Input Field

```lua
local inputField = basalt.create("Input", { text = "", placeholder = "Type here..." })
container:addChild(inputField)
inputField:registerCallback("char", function(self, char)
    -- Update something, e.g., show the entered text
    print("Key pressed: " .. char)
end)
```

### Plotting a Graph

```lua
local graph = basalt.create("Graph", { width = 30, height = 10, minValue = 0, maxValue = 100 })
container:addChild(graph)
graph:addSeries("Temperature", "*", colors.red, colors.black, 30)
graph:addPoint("Temperature", 55)
graph:addPoint("Temperature", 60)
graph:addPoint("Temperature", 45)
```

