{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Dedicated Server Workflow Notice",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-Command",
				"Write-Host 'Local emulator/world deployment is retired. Push to GitHub and use the dedicated-server installer/update flow.' -ForegroundColor Yellow; exit 1"
			],
			"group": "none",
			"presentation": {
				"echo": true,
				"reveal": "always",
				"focus": false,
				"panel": "shared",
				"clear": true
			},
			"problemMatcher": []
		},
		{
			"label": "Build Deploy Index",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-ExecutionPolicy",
				"Bypass",
				"-File",
				"${workspaceFolder}/scripts/build-deploy-index.ps1"
			],
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"presentation": {
				"echo": true,
				"reveal": "always",
				"focus": false,
				"panel": "shared",
				"clear": true
			},
			"problemMatcher": []
		},
		{
			"label": "Build Deploy Index",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-ExecutionPolicy",
				"Bypass",
				"-File",
				"scripts/build-deploy-index.ps1"
			],
			"isBackground": false,
			"problemMatcher": [],
			"group": "build"
		}
	]
}